<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ui.view.UpdateTodoActivity">

    <TextView
        android:id="@+id/titleForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cập nhật công việc"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tên công việc -->
    <TextView
        android:id="@+id/labelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên công việc"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/titleForm"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/editTextName"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Nhập tên công việc"
        android:inputType="text"
        android:autofillHints="name"
        android:padding="12dp"
        android:background="@drawable/border_item"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/labelName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mô tả -->
    <TextView
        android:id="@+id/labelDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mô tả"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/editTextName"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/editTextDescription"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:hint="Nhập mô tả công việc"
        android:inputType="text|textMultiLine"
        android:autofillHints="name"
        android:padding="12dp"
        android:gravity="top"
        android:background="@drawable/border_item"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/labelDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hạn chót -->
    <TextView
        android:id="@+id/labelDeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hạn chót"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/editTextDescription"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/editTextDeadline"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Chọn hạn chót"
        android:textSize="14sp"
        android:textAlignment="textStart"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical|start"
        android:background="@drawable/border_item"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/labelDeadline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Trạng thái -->
    <TextView
        android:id="@+id/labelStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trạng thái"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/editTextDeadline"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerStatus"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@drawable/border_item"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/labelStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nút Hủy và Cập nhật -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:gravity="end"
        android:spacing="12dp"
        app:layout_constraintTop_toBottomOf="@+id/spinnerStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/buttonCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Hủy"
            android:textColor="#FF5252"
            android:background="@drawable/border_item"
            android:backgroundTint="@android:color/transparent" />

        <Button
            android:id="@+id/buttonUpdate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cập nhật"
            android:textColor="@android:color/white"
            android:background="#4CAF50" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

